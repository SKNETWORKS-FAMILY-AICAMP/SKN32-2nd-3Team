# ===================================
# 데이터베이스
# ott_db.sql 은 스키마/적재 스크립트(셋업용)라 추적 유지함
# 실제 로컬 덤프 파일만 패턴으로 제외
# ===================================
*.db
*.sqlite
*.sqlite3
*_dump.sql
dump_*.sql
backup*.sql

